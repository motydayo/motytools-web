{
  "framework": "astro",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/memomail/lp", "destination": "/memomail/", "permanent": false },
    { "source": "/memomail/lp/", "destination": "/memomail/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/privacy/pitto-kigen", "destination": "/privacy/pitto-kigen.html" }
  ]
}
