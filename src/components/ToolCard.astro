---
import type { Tool } from '../data/tools';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
---

<a href={`/${tool.slug}/`} class={`tool-card cat-${tool.category}`}>
  <span class="icon" aria-hidden="true">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={tool.icon} />
  </span>
  <span class="name">{tool.name}</span>
  <span class="desc">{tool.short}</span>
</a>
