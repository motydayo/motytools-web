---
import BaseLayout from './BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import { SITE } from '../config';
import { getTool, getCategory, relatedTools } from '../data/tools';

export interface Faq {
  q: string;
  /** プレーンテキストのみ（構造化データにそのまま出るためHTML不可） */
  a: string;
}

interface Props {
  slug: string;
  /** H1直下のリード文（1〜2文。検索意図に直接答える） */
  lead: string;
  faqs: Faq[];
}

const { slug, lead, faqs } = Astro.props;
const tool = getTool(slug);
const category = getCategory(tool.category);
const path = `/${tool.slug}/`;
const related = relatedTools(slug);

const jsonLd: object[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: `${tool.name} - ${SITE.name}`,
    url: `${SITE.url}${path}`,
    description: tool.description,
    applicationCategory: 'UtilityApplication',
    operatingSystem: 'Any',
    inLanguage: 'ja',
    isAccessibleForFree: true,
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'JPY' },
    datePublished: SITE.toolsPublished,
    publisher: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE.url + '/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: SITE.url + '/tools/' },
      { '@type': 'ListItem', position: 3, name: tool.name, item: SITE.url + path },
    ],
  },
];

if (faqs.length > 0) {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}
---

<BaseLayout
  title={tool.title}
  description={tool.description}
  path={path}
  ogImage={`/og/${tool.slug}.png`}
  jsonLd={jsonLd}
>
  <div class="container">
    <nav class="breadcrumb" aria-label="パンくずリスト">
      <ol>
        <li><a href="/">ホーム</a></li>
        <li><a href="/tools/">ツール一覧</a></li>
        <li aria-current="page">{tool.name}</li>
      </ol>
    </nav>

    <div class="tool-hero">
      <span class={`chip cat-${tool.category}`}>{category.name}</span>
      <h1>{tool.name}</h1>
      <p class="lead">{lead}</p>
    </div>

    <slot />

    <div class="article">
      <div class="prose">
        <slot name="article" />
      </div>

      {faqs.length > 0 && (
        <section class="mt-8" aria-labelledby="faq-heading">
          <div class="section-heading">
            <h2 id="faq-heading">よくある質問</h2>
          </div>
          <div class="faq">
            {faqs.map((f) => (
              <details>
                <summary>{f.q}</summary>
                <p class="faq-a">{f.a}</p>
              </details>
            ))}
          </div>
        </section>
      )}
    </div>

    <section class="mt-8" aria-labelledby="related-heading">
      <div class="section-heading">
        <h2 id="related-heading">関連ツール</h2>
        <a class="more" href="/tools/">すべてのツールを見る</a>
      </div>
      <div class="cards">
        {related.map((t) => <ToolCard tool={t} />)}
      </div>
    </section>
  </div>
</BaseLayout>
