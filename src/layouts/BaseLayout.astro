---
import { SITE } from '../config';
import { TOOLS, CATEGORIES } from '../data/tools';
import '../styles/global.css';

interface Props {
  /** ページタイトル（「 | motytools」が付く）。absoluteTitle=true ならそのまま出す */
  title: string;
  absoluteTitle?: boolean;
  description: string;
  /** 先頭スラッシュ始まり・末尾スラッシュ込みのパス（例: '/percent/'） */
  path: string;
  ogImage?: string;
  /** 'auto' = ライト/ダーク切替あり, 'dark' = 常にダーク（トップ用） */
  appearance?: 'auto' | 'dark';
  jsonLd?: object[];
  noindex?: boolean;
}

const {
  title,
  absoluteTitle = false,
  description,
  path,
  ogImage = '/og/default.png',
  appearance = 'auto',
  jsonLd = [],
  noindex = false,
} = Astro.props;

const fullTitle = absoluteTitle ? title : `${title} | ${SITE.name}`;
const canonical = `${SITE.url}${path}`;
const ogImageUrl = `${SITE.url}${ogImage}`;
---

<!doctype html>
<html lang="ja" data-theme={appearance === 'dark' ? 'dark' : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {SITE.searchConsoleToken && <meta name="google-site-verification" content={SITE.searchConsoleToken} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap.xml" />

    {appearance === 'auto' && (
      <script is:inline>
        (function () {
          try {
            var t = localStorage.getItem('mt-theme');
            if (t !== 'light' && t !== 'dark') {
              t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }
            document.documentElement.setAttribute('data-theme', t);
          } catch (e) {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        })();
      </script>
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+JP:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />

    {jsonLd.map((obj) => <script type="application/ld+json" set:html={JSON.stringify(obj)} />)}

    {SITE.gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.gaId}`}></script>
        <script is:inline define:vars={{ gaId: SITE.gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
    <script
      async
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${SITE.adsenseClient}`}
      crossorigin="anonymous"></script>
  </head>
  <body>
    <a class="skip-link" href="#main">本文へスキップ</a>
    <header class="site-header">
      <div class="inner">
        <a href="/" class="logo">moty<span>tools</span></a>
        <nav class="header-nav" aria-label="サイト内メニュー">
          <a href="/tools/">ツール一覧</a>
          {appearance === 'auto' && (
            <button class="theme-toggle" type="button" aria-label="ライト/ダークテーマを切り替える">
              <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
              <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
            </button>
          )}
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="cols">
          {CATEGORIES.map((cat) => (
            <div>
              <h2>{cat.name}</h2>
              <ul>
                {TOOLS.filter((t) => t.category === cat.id).map((t) => (
                  <li><a href={`/${t.slug}/`}>{t.name}</a></li>
                ))}
              </ul>
            </div>
          ))}
          <div>
            <h2>motytools</h2>
            <ul>
              <li><a href="/">ホーム</a></li>
              <li><a href="/tools/">ツール一覧</a></li>
              <li><a href="/memomail/">メモびゅん（iOSアプリ）</a></li>
              <li><a href="/price-scan/">ピッと最安（iOSアプリ）</a></li>
              <li><a href="/privacy">プライバシーポリシー</a></li>
            </ul>
          </div>
        </div>
        <div class="legal">
          <p>© 2026 motytools</p>
          <p>すべてのツールは無料・登録不要で、データはブラウザ内で処理されます。</p>
        </div>
      </div>
    </footer>

    {appearance === 'auto' && (
      <script>
        const btn = document.querySelector('.theme-toggle');
        btn?.addEventListener('click', () => {
          const cur = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
          const next = cur === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          try {
            localStorage.setItem('mt-theme', next);
          } catch {}
        });
      </script>
    )}
  </body>
</html>
