---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import { TOOLS } from '../data/tools';

const popular = TOOLS.slice(0, 4);
---

<BaseLayout
  title="ページが見つかりません"
  description="お探しのページは見つかりませんでした。motytoolsの無料Webツール一覧からお探しください。"
  path="/404/"
  noindex={true}
>
  <div class="container">
    <div class="wrap">
      <p class="code">404</p>
      <h1>ページが見つかりません</h1>
      <p class="text-2">
        お探しのページは移動または削除された可能性があります。URLをご確認いただくか、ツール一覧からお探しください。
      </p>
      <div class="actions">
        <a class="btn btn-primary" href="/tools/">ツール一覧を見る</a>
        <a class="btn btn-secondary" href="/">ホームへ戻る</a>
      </div>
      <section class="mt-8" aria-label="よく使われるツール">
        <div class="section-heading">
          <h2 class="h2">よく使われるツール</h2>
        </div>
        <div class="cards">
          {popular.map((t) => <ToolCard tool={t} />)}
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .wrap {
    padding: var(--sp-8) 0;
    text-align: center;
  }
  .code {
    font-size: var(--fs-xl);
    font-weight: 800;
    color: var(--text-3);
    letter-spacing: 0.1em;
  }
  h1 {
    font-size: var(--fs-2xl);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: var(--sp-2) 0 var(--sp-3);
  }
  .wrap > p.text-2 {
    max-width: 34em;
    margin-inline: auto;
  }
  .actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-top: var(--sp-5);
  }
  .wrap section {
    text-align: left;
  }
</style>
